ARG CONFLUENT_VERSION=7.2.4

# Install Confluent Avro converter
FROM confluentinc/cp-kafka-connect:${CONFLUENT_VERSION} as cp
# Reassign version
ARG CONFLUENT_VERSION
RUN confluent-hub install --no-prompt confluentinc/kafka-connect-avro-converter:${CONFLUENT_VERSION}

# Install Debezium MySQL Connector from Maven
# Using pinned digest for amd64 architecture to ensure consistency with production
FROM quay.io/strimzi/kafka@sha256:65744f0616afeb3dc4f7c59fe79c8e0cadafe1e057ad50bfa87ae8753ac8bca3 
USER root:root

# Copy kafka_connect_config_generator.sh and kafka_connect_run.sh from local files
# These scripts are needed to generate /tmp/strimzi-connect.properties from environment variables
# The current base image uses file-based config, but production uses the generator script
# These files were extracted from production image v2 to ensure compatibility
COPY kafka_connect_config_generator.sh /opt/kafka/kafka_connect_config_generator.sh
COPY kafka_connect_run.sh /opt/kafka/kafka_connect_run.sh

# Copy Confluent Avro converter plugin from the Confluent image
RUN mkdir -p /opt/kafka/plugins/avro/
COPY --from=cp /usr/share/confluent-hub-components/confluentinc-kafka-connect-avro-converter/lib /opt/kafka/plugins/avro/

# Connector plugin - Debezium MySQL
RUN mkdir -p /opt/kafka/plugins/debezium-source \
    && curl -f -L \
    --output /opt/kafka/plugins/debezium-source.tgz \
    https://repo1.maven.org/maven2/io/debezium/debezium-connector-mysql/3.0.2.Final/debezium-connector-mysql-3.0.2.Final-plugin.tar.gz \
    && tar xvfz /opt/kafka/plugins/debezium-source.tgz -C /opt/kafka/plugins/debezium-source \
    && rm -vf /opt/kafka/plugins/debezium-source.tgz

# Install Debezium JDBC Connector
RUN mkdir -p /opt/kafka/plugins/debezium-jdbc \
    && curl -f -L \
    --output /opt/kafka/plugins/debezium-jdbc.tgz \
    https://repo1.maven.org/maven2/io/debezium/debezium-connector-jdbc/3.0.2.Final/debezium-connector-jdbc-3.0.2.Final-plugin.tar.gz \
    && tar xvfz /opt/kafka/plugins/debezium-jdbc.tgz -C /opt/kafka/plugins/debezium-jdbc \
    && rm -vf /opt/kafka/plugins/debezium-jdbc.tgz

# Install Confluent JDBC Sink Connector
RUN mkdir -p /opt/kafka/plugins/confluent-sink-jdbc \
    && curl -f -L \
    --output /opt/kafka/plugins/confluent-sink-jdbc.zip \
    https://d2p6pa21dvn84.cloudfront.net/api/plugins/confluentinc/kafka-connect-jdbc/versions/10.7.4/confluentinc-kafka-connect-jdbc-10.7.4.zip \
    && unzip /opt/kafka/plugins/confluent-sink-jdbc.zip -d /opt/kafka/plugins/confluent-sink-jdbc \
    && rm -vf /opt/kafka/plugins/confluent-sink-jdbc.zip

# Install MySQL JDBC driver for Confluent JDBC Sink Connector
RUN mkdir -p /opt/kafka/plugins/mysql-connector-java \
    && curl -f -L \
    --output /opt/kafka/plugins/mysql-connector-java.jar \
    https://repo1.maven.org/maven2/mysql/mysql-connector-java/8.0.22/mysql-connector-java-8.0.22.jar

# Create custom-config directory and empty properties file (required by kafka_connect_run.sh script)
# The script tries to source this file at line 21, and will fail if it doesn't exist
RUN mkdir -p /opt/kafka/custom-config \
    && touch /opt/kafka/custom-config/kafka-connect.properties

# Ensure correct permissions for the plugins
USER 1001
